{
  "expo": {
    "name": "ZeroHour",
    "slug": "zerohour",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.zerohour.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "ZeroHour uses Face ID to secure your session."
      }
    },
    "android": {
      "package": "com.zerohour.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#05070D"
      },
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT", "VIBRATE"]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sharing",
      "expo-font",
      "expo-splash-screen",
      "expo-local-authentication",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "zerohour-app"
      }
    }
  }
}
